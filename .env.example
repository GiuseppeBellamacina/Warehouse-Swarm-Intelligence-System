# -----------------------------------------------
# Backend — template variabili d'ambiente
# Per sviluppo locale: copia in .env e personalizza.
# Per Render (produzione): imposta queste variabili
# nella dashboard del servizio.
# -----------------------------------------------

HOST=0.0.0.0
PORT=8000

# Origini frontend autorizzate (CORS), separate da virgola
# Sviluppo: http://localhost:3000,http://localhost:5173
# Produzione: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Telegram Bot — lascia vuoti per disabilitare le notifiche
# 1. Crea un bot con @BotFather su Telegram e copia il token
# 2. Ottieni il tuo Chat ID con @userinfobot
# Su Render: imposta queste variabili nella dashboard del servizio
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
