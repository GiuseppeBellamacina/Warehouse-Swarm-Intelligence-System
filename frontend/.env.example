# -----------------------------------------------
# Frontend — template variabili d'ambiente
# Per sviluppo locale: copia in .env e personalizza.
# Per Vercel (produzione): imposta queste variabili
# nella dashboard del progetto (Settings > Environment Variables).
# -----------------------------------------------

# URL del backend (senza slash finale)
# Sviluppo: http://localhost:8000
# Produzione: https://your-backend.onrender.com
VITE_BACKEND_URL=http://localhost:8000
